generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String?
  googleId      String?  @unique
  collegeName   String?
  collegeDomain String?
  avatarUrl     String?
  bio           String?
  phone         String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listings              Listing[]
  wishlistItems         WishlistItem[]
  sentMessages          Message[]      @relation("SentMessages")
  conversationsAsBuyer  Conversation[] @relation("BuyerConversations")
  conversationsAsSeller Conversation[] @relation("SellerConversations")
  notifications         Notification[]
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Decimal
  type        ListingType
  category    Category
  condition   ItemCondition
  status      ListingStatus @default(ACTIVE)
  location    String?
  sellerId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller        User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images        ListingImage[]
  wishlistItems WishlistItem[]
  conversations Conversation[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model ListingImage {
  id        String   @id @default(uuid())
  url       String
  publicId  String?
  listingId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id        String   @id @default(uuid())
  buyerId   String
  sellerId  String
  listingId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([buyerId, sellerId, listingId])

  @@index([buyerId])

@@index([sellerId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ListingType {
  SELL
  RENT
}

enum ListingStatus {
  ACTIVE
  SOLD
  RENTED
  INACTIVE
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum Category {
  BOOKS
  NOTES
  ELECTRONICS
  SUPPLIES
  ESSENTIALS
  LAB_EQUIPMENT
  OTHERS
}

enum NotificationType {
  MESSAGE
  LISTING
  WISHLIST
  SYSTEM
}
